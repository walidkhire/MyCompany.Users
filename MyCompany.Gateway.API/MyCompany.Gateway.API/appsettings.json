{
  "ReverseProxy1": {
    "Routes": {
      "produits-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/produits/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/produits/{catch-all}" } // 🔹 ALIGNÉ : avec le 's' comme votre URL directe
        ]
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/users/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/users/{catch-all}" }
        ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/orders/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/orders/{catch-all}" }
        ]
      },
      "auths-route": {
        "ClusterId": "auths-cluster",
        "Match": {
          "Path": "/auths/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/auths/{catch-all}" }
        ]
      }
    },
    "Clusters": {
      "users-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7070"
          }
        }
      },
      "orders-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7259"
          }
        }
      },
      "auths-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7070"
          }
        }
      }
    }
  },
  "Jwt": {
    "Issuer": "MyCompany",
    "Audience": "MyCompanyApis",
    "Key": "SUPER_SECRET_KEY_123456_SECURISEE_ET_ASSEZ_LONGUE_32"
  }
}