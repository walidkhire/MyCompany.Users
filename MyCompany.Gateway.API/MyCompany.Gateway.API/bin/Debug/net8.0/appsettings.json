{
  "ReverseProxy": {
    "Routes": {
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/users/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/users" }
        ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/orders/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/orders" }
        ]
      },
      "auths-route": {
        "ClusterId": "auths-cluster",
        "Match": {
          "Path": "/auths/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auths" }
        ]
      }
    },
    "Clusters": {
      "users-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7070/"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7259/"
          }
        }
      },
      "auths-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7070/"
          }
        }
      }
    }
  },
  "Jwt": {
    "Issuer": "MyCompany",
    "Audience": "MyCompanyUsers",
    "Key": "SUPER_SECRET_KEY_123456"
  }
}
